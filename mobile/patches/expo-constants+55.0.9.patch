diff --git a/node_modules/expo-constants/ios/EXConstants.podspec b/node_modules/expo-constants/ios/EXConstants.podspec
index fc4608a..14568ba 100644
--- a/node_modules/expo-constants/ios/EXConstants.podspec
+++ b/node_modules/expo-constants/ios/EXConstants.podspec
@@ -1,4 +1,5 @@
 require 'json'
+require 'shellwords'
 
 package = JSON.parse(File.read(File.join(__dir__, '..', 'package.json')))
 
@@ -34,10 +35,18 @@ Pod::Spec.new do |s|
     s.source_files = "**/*.{h,m,swift}"
   end
 
-  env_vars = ENV['PROJECT_ROOT'] ? "PROJECT_ROOT=#{ENV['PROJECT_ROOT']} " : ""
+  # Use absolute path + Shellwords so project paths with spaces (and optional PROJECT_ROOT) work.
+  # CocoaPods substitutes $PODS_TARGET_SRCROOT at pod-install time without quoting, which breaks bash -c.
+  get_app_config_script = File.expand_path('../scripts/get-app-config-ios.sh', __dir__)
+  env_prefix = if (root = ENV['PROJECT_ROOT'])
+    "PROJECT_ROOT=#{Shellwords.escape(root)} "
+  else
+    ''
+  end
+  inner_cmd = "#{env_prefix}#{Shellwords.escape(get_app_config_script)}"
   script_phase = {
     :name => 'Generate app.config for prebuilt Constants.manifest',
-    :script => "bash -l -c \"#{env_vars}$PODS_TARGET_SRCROOT/../scripts/get-app-config-ios.sh\"",
+    :script => "bash -l -c #{Shellwords.escape(inner_cmd)}",
     :execution_position => :before_compile
   }
   # :always_out_of_date is only available in CocoaPods 1.13.0 and later
diff --git a/node_modules/expo-constants/scripts/get-app-config-ios.sh b/node_modules/expo-constants/scripts/get-app-config-ios.sh
index b612e09..dd267b4 100755
--- a/node_modules/expo-constants/scripts/get-app-config-ios.sh
+++ b/node_modules/expo-constants/scripts/get-app-config-ios.sh
@@ -11,7 +11,7 @@ EXPO_CONSTANTS_PACKAGE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
 # `$PROJECT_DIR` is passed by Xcode as the directory to the xcodeproj file.
 # in classic main project setup it is something like /path/to/app/ios
 # in new style pod project setup it is something like /path/to/app/ios/Pods
-PROJECT_DIR_BASENAME=$(basename $PROJECT_DIR)
+PROJECT_DIR_BASENAME=$(basename "$PROJECT_DIR")
 if [ "x$PROJECT_DIR_BASENAME" != "xPods" ]; then
   exit 0
 fi
@@ -22,8 +22,15 @@ PROJECT_ROOT=${PROJECT_ROOT:-"$EXPO_CONSTANTS_PACKAGE_DIR/../.."}
 
 cd "$PROJECT_ROOT" || exit
 
+# Xcode / CocoaPods do not always export BUNDLE_FORMAT for this script phase; default matches
+# the shallow EXConstants.bundle layout used by CocoaPods resource bundles.
+if [ -z "$BUNDLE_FORMAT" ]; then
+  BUNDLE_FORMAT="shallow"
+fi
+
 if [ "$BUNDLE_FORMAT" == "shallow" ]; then
   RESOURCE_DEST="$DEST/$RESOURCE_BUNDLE_NAME"
+  mkdir -p "$RESOURCE_DEST"
 elif [ "$BUNDLE_FORMAT" == "deep" ]; then
   RESOURCE_DEST="$DEST/$RESOURCE_BUNDLE_NAME/Contents/Resources"
   mkdir -p "$RESOURCE_DEST"
