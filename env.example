# --- Public site URL (required in production: https://hidayah.io) ---
# Used for:
# - Server redirects from /auth/callback (getSiteUrl)
# - Supabase email links: signup confirmation & password reset (getAuthSiteUrl on the client)
# Custom SMTP is configured in Supabase Dashboard → Project Settings → Auth → SMTP (not here).
NEXT_PUBLIC_SITE_URL=https://hidayah.io

# --- Supabase (required for auth + database) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: service role for Stripe webhooks & admin writes (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (subscriptions) ---
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price ID for Premium subscription (create in Stripe Dashboard → Products)
STRIPE_PRICE_PREMIUM=price_xxx

# Optional: daily free-tier access limit for reader/session routes.
FREE_DAILY_READER_LIMIT=3

# Optional: Vercel sets VERCEL_URL automatically
